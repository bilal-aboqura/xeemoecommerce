# ──────────────────────────────────────────────────────────────
# Xeemo Ecommerce — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. (Only `.env.example` is tracked.)
# ──────────────────────────────────────────────────────────────

# ── Supabase (get these from your Supabase project: Project Settings ▸ API) ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key-keep-secret

# ── Kashier (Egyptian payment gateway) — TEST keys first, swap to LIVE later ──
# Dashboard: https://merchants.kashier.io
KASHIER_MERCHANT_ID=MID-XXXXX
KASHIER_API_KEY=test-api-key
# Set to "true" while testing, "false" when going live
KASHIER_TESTMODE=true
# Shared secret used to verify Kashier webhook signatures (set in Kashier dashboard)
KASHIER_WEBHOOK_SECRET=wh-secret

# ── Public URLs (used to build Kashier redirect & webhook URLs) ──
# In dev use the Next dev URL. In prod use your real domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Google Sheets mirror (reuse your existing Apps Script webhook) ──
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec

# ── Notifications ──
# WhatsApp number (E.164, no "+") that receives new-order alerts, e.g. 201150301033
WHATSAPP_ALERT_NUMBER=201150301033

# ── First admin owner (used to seed the owner account in Phase 2) ──
ADMIN_EMAIL=owner@xeemo-eg.com
ADMIN_PASSWORD=change-me
